# Secret query param value: visit /?viewstats=YOUR_SECRET once to reveal the counter.
VIEW_COUNTER_SECRET=

# Upstash Redis (free tier) — required for persistent counts on Vercel.
# Create at https://console.upstash.com/ and add both vars in Vercel project settings.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
